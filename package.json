{
  "name": "streamfold",
  "version": "0.7.0",
  "private": true,
  "author": "Streamfold Contributors",
  "license": "UNLICENSED",
  "description": "归页：本地优先的个人社媒账号、内容与数据工作台",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "dist": "pnpm build && electron-builder",
    "dist:dir": "pnpm build && electron-builder --dir",
    "dist:win": "pnpm build && electron-builder --win",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:linux": "pnpm build && electron-builder --linux",
    "preview": "electron-vite preview",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "pnpm build && pnpm test:ui:run",
    "test:ui:run": "playwright test --config playwright.config.ts",
    "test:smoke": "pnpm build && electron-builder --dir --publish never && pnpm test:package-plugins -- release && pnpm test:package-runtime -- release",
    "test:smoke:dev": "pnpm build && node scripts/smoke.mjs",
    "sdk:build": "pnpm --filter @streamfold/plugin-sdk build",
    "sdk:test": "vitest run packages/plugin-sdk/test",
    "plugin:official-webhook:build": "pnpm sdk:build && node scripts/build-official-webhook.mjs build",
    "plugin:official-webhook:verify": "pnpm sdk:build && node scripts/build-official-webhook.mjs verify",
    "test:package-plugins": "pnpm sdk:build && node scripts/verify-packaged-plugins.mjs",
    "test:package-runtime": "node scripts/smoke-packaged.mjs",
    "test:update-artifacts": "node scripts/verify-update-artifacts.mjs",
    "benchmark:content-search": "node scripts/run-content-search-benchmark.mjs"
  },
  "dependencies": {
    "electron-updater": "6.8.9",
    "quickjs-emscripten": "^0.32.0",
    "vue": "3.5.39",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@electron/asar": "3.4.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "24.13.3",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-vue": "6.0.7",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "js-yaml": "4.3.0",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "engines": {
    "node": ">=22.21.1",
    "pnpm": ">=10"
  },
  "build": {
    "appId": "com.streamfold.app",
    "productName": "归页",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/plugins",
        "to": "plugins",
        "filter": [
          "*.streamfold-plugin"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "Streamfold-${version}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "归页"
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "Streamfold-${version}-macos-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "Streamfold-${version}-linux-${arch}.${ext}"
    }
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
