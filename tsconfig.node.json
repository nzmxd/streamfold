{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "electron", "vitest/globals"],
    "allowImportingTsExtensions": false
  },
  "include": [
    "electron.vite.config.ts",
    "playwright.config.ts",
    "vitest.config.ts",
    "tests/electron/**/*.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
