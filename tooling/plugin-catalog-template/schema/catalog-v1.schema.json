{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://streamfold.example/schema/plugin-catalog-v1.schema.json",
  "title": "Streamfold signed plugin catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "expiresAt", "entries", "signature"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time", "maxLength": 40 },
    "expiresAt": { "type": "string", "format": "date-time", "maxLength": 40 },
    "entries": {
      "type": "array",
      "maxItems": 5000,
      "items": { "$ref": "#/$defs/entry" }
    },
    "signature": {
      "type": "string",
      "pattern": "^(?:[A-Za-z0-9+/]{4}){21}[A-Za-z0-9+/]{2}==$"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9._-]{1,126}[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "maxLength": 80,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pluginId", "version", "downloadUrl", "packageHash", "publisherKeyId",
        "publisherPublicKey", "minimumAppVersion", "revoked"
      ],
      "properties": {
        "pluginId": { "$ref": "#/$defs/identifier" },
        "version": { "$ref": "#/$defs/version" },
        "downloadUrl": { "type": "string", "format": "uri", "pattern": "^https://", "maxLength": 2048 },
        "packageHash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "publisherKeyId": { "$ref": "#/$defs/identifier" },
        "publisherPublicKey": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "minimumAppVersion": { "$ref": "#/$defs/version" },
        "maximumAppVersion": { "$ref": "#/$defs/version" },
        "revoked": { "type": "boolean" },
        "revokedReason": { "type": "string", "minLength": 1, "maxLength": 300 }
      },
      "allOf": [
        {
          "if": { "properties": { "revoked": { "const": true } }, "required": ["revoked"] },
          "then": { "required": ["revokedReason"] },
          "else": { "not": { "required": ["revokedReason"] } }
        }
      ]
    }
  }
}
